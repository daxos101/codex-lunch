# PostgreSQL (required by API, worker, migrations, and seed)
DATABASE_URL=postgresql://lunch:lunch@localhost:5432/lunch
# Set to require only when the provider presents a publicly trusted certificate.
DATABASE_SSL=disable

# API
API_HOST=0.0.0.0
API_PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
LOG_LEVEL=info

# Browser build. Leave blank when the web server proxies /api on the same origin.
VITE_API_BASE_URL=
