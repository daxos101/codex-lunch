{
  "name": "hagersten-lunch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "db:migrate": "pnpm --filter @lunch/database db:migrate",
    "db:seed": "pnpm --filter @lunch/database db:seed",
    "dev": "pnpm --parallel --filter @lunch/api --filter @lunch/web dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint . --max-warnings=0",
    "preview:live": "pnpm --filter @lunch/worker exec tsx src/live-preview.ts",
    "restaurants:build": "node scripts/build-restaurant-seed.mjs",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "typecheck": "pnpm -r --if-present typecheck",
    "worker": "pnpm --filter @lunch/worker exec tsx src/cli.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
