    "@lunch/database": "workspace:*",
    "@lunch/shared": "workspace:*",
    "fastify": "^5.4.0",
    "pg": "^8.16.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "tsx": "^4.20.3"
  }
}
