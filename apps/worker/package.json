{
  "name": "@lunch/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "collect": "tsx src/cli.ts collect all",
    "dev": "tsx src/cli.ts schedule",
    "failures": "tsx src/cli.ts failures",
    "lint": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js schedule",
    "schedule": "tsx src/cli.ts schedule",
    "status": "tsx src/cli.ts status",
    "summary": "tsx src/cli.ts summary",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lunch/database": "workspace:*",
    "@lunch/scraping": "workspace:*",
    "@lunch/shared": "workspace:*",
    "cheerio": "^1.1.0",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
